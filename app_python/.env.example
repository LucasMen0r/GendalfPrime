# ==============================================================================
# GendalfPrime — Variáveis de Ambiente (Template)
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA versione o arquivo .env com credenciais reais.
# ==============================================================================

# ─── Banco de Dados PostgreSQL (Supabase) ────────────────────────────────────
DB_HOST=seu-host.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.seu_usuario
DB_NAME=postgres
DB_PASS=SUA_SENHA_SEGURA_AQUI

# ─── Ollama (LLM Local) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_CHAT_MODEL=deepseek-r1:8b

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://seu_projeto.supabase.co
SUPABASE_KEY=sua_chave_publica_aqui

# ─── Django ──────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=gere_uma_chave_secreta_aqui
DJANGO_DEBUG=True
